# Use Eclipse Temurin JDK 21
FROM eclipse-temurin:21-jdk-jammy

# Set working directory inside container
WORKDIR /app

# Copy Maven wrapper and configuration
COPY mvnw mvnw
COPY .mvn/ .mvn/
COPY pom.xml pom.xml

# Download dependencies once (cached in Docker layer)
RUN ./mvnw dependency:go-offline

# Expose the default Spring Boot port
EXPOSE 8080

# Default command to run the app using Spring Boot DevTools
# Assumes that target/classes are mounted from host (Eclipse builds automatically)
CMD ["./mvnw", "spring-boot:run"]
